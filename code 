// 🔍 Enhanced Search Function
function searchRecipe() {
  const query = document.getElementById("searchInput").value.toLowerCase().trim();
  const resultDiv = document.getElementById("result");

  if (!query) {
    resultDiv.innerHTML = "<p class='text-center text-yellow-200 text-lg'>Please enter a recipe name or keyword!</p>";
    return;
  }

  // Keywords for better matching
  const keywordMap = {
    "chai": ["tea", "masala tea"],
    "coffee": ["tea"],
    "bread": ["naan", "roti", "chapati", "puri", "paratha"],
    "rice": ["biryani", "pulao", "fried rice", "lemon rice"],
    "curry": ["butter chicken", "paneer", "dal", "chana"],
    "snack": ["samosa", "pakora", "vada", "tikka"],
    "sweet": ["kheer", "gulab jamun", "jalebi", "laddu"],
    "breakfast": ["idli", "dosa", "paratha", "poha", "upma"]
  };

  let matches = [];

  indianRecipes.forEach(recipe => {
    const nameMatch = recipe.name.toLowerCase().includes(query);
    const categoryMatch = recipe.category.toLowerCase().includes(query);
    const ingredientMatch = recipe.ingredients.some(ing => ing.toLowerCase().includes(query));
    
    // Check keyword maps
    let keywordMatch = false;
    for (let key in keywordMap) {
      if (query.includes(key)) {
        keywordMatch = keywordMap[key].some(recipe_name => 
          recipe.name.toLowerCase().includes(recipe_name)
        );
      }
    }

    if (nameMatch || categoryMatch || ingredientMatch || keywordMatch) {
      matches.push(recipe);
    }
  });

  displayResults(matches, query);
}

// Quick search function
function quickSearch(category) {
  const matches = indianRecipes.filter(r => r.category.toLowerCase().includes(category));
  displayResults(matches, category.toUpperCase());
}

// Show all recipes
function showAllRecipes() {
  displayResults(indianRecipes, "All Recipes");
}

// Display results
function displayResults(recipes, query) {
  const resultDiv = document.getElementById("result");

  if (recipes.length === 0) {
    resultDiv.innerHTML = `<p class='text-center text-yellow-200 text-lg'>No recipes found for "${query}". Try another search!</p>`;
    return;
  }

  let output = `<h2 class="text-2xl font-bold mb-4 text-yellow-200">Found ${recipes.length} recipe(s) for "${query}" 🎉</h2>`;

  recipes.forEach((recipe, index) => {
    const emoji = getCategoryEmoji(recipe.category);
    output += `
      <div class="recipe-card bg-white text-black p-5 rounded-lg mb-4 shadow-lg border-l-4 border-yellow-400">
        <h2 class="text-2xl font-bold text-purple-600 mb-2">${emoji} ${recipe.name}</h2>
        <p class="text-sm text-gray-500 mb-3"><strong>Category:</strong> ${recipe.category}</p>
        
        <div class="mb-3">
          <p class="font-semibold text-purple-700 mb-2">🥘 Ingredients:</p>
          <p class="text-gray-700">${recipe.ingredients.join(" • ")}</p>
        </div>
        
        <div>
          <p class="font-semibold text-purple-700 mb-2">👨‍🍳 Instructions:</p>
          <p class="text-gray-700">${recipe.instructions}</p>
        </div>
      </div>
    `;
  });

  resultDiv.innerHTML = output;
}

// Helper function to get category emoji
function getCategoryEmoji(category) {
  const emojis = {
    "breakfast": "🌅",
    "rice": "🍚",
    "curry": "🍛",
    "bread": "🍞",
    "snacks": "🥟",
    "sides": "🥬",
    "dessert": "🍰",
    "vegetable": "🥦"
  };
  return emojis[category] || "🍳";
}

